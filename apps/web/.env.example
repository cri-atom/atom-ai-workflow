# Vercel Production: PUBLIC_DOCS_URL en Environment Variables
# El API va por proxy same-origin (apps/web/vercel.json) — no hace falta PUBLIC_API_URL en Vercel
PUBLIC_DOCS_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
# PUBLIC_DOCS_URL=https://criatom.mintlify.app
# Solo si quieres llamar a Render directo (requiere CORS): PUBLIC_API_CROSS_ORIGIN=true + PUBLIC_API_URL=https://...
# Copia del mapa para fallback offline: npm run sync-docs-map -w @atom-ai/api → apps/web/public/workflow-map.json

# API (Express) — en Render: WEB_ORIGIN = URL Vercel; DOCS_ORIGIN = URL Mintlify
PORT=4000
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:4321
DOCS_ORIGIN=http://localhost:3000
# Producción ejemplo:
# API_ORIGIN=https://atom-ai-api.onrender.com
# WEB_ORIGIN=https://tu-app.vercel.app
# DOCS_ORIGIN=https://tu-org.mintlify.app

# Supabase (optional in v1 — API runs without it)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Toolkit / LLM providers (server-only — never expose in apps/web)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
ATOM_PROVIDER=claude
ATOM_MODEL=claude-sonnet-4-20250514

# Astro (apps/web/.env) y Mintlify (docs/.env) — URL pública del API para el mapa
PUBLIC_DOCS_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
